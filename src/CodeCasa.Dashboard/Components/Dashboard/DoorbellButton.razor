<div class="doorbell-button-container @(Visible ? "visible" : "hidden")">
    <MudIconButton Icon="@Icons.Material.Filled.Videocam" 
                   Color="Color.Inherit" 
                   OnClick="OnClick" />
</div>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
}

<style>
.doorbell-button-container {
    position: fixed;
    bottom: 6px;
    left: 6px;
    opacity: 0;
    transition: opacity 0.5s ease-in-out;
}

.doorbell-button-container.visible {
    opacity: 1;
}

.doorbell-button-container.hidden {
    opacity: 0;
}
</style>
